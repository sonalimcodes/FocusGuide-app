<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stay Focused"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:paddingTop="40dp"
            android:paddingBottom="10dp"/>

        <!-- Status Text -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Idle"
            android:textSize="16sp"
            android:textColor="#455A64"
            android:paddingBottom="20dp"/>

        <!-- Duration Input -->
        <EditText
            android:id="@+id/etMinutes"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Enter focus duration (minutes)"
            android:inputType="number"
            android:padding="12dp"
            android:layout_marginBottom="15dp"
            android:background="@android:drawable/edit_text"
            android:textSize="16sp"/>

        <!-- Start Button -->
        <Button
            android:id="@+id/btnStartFocus"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Start Focus Mode"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:padding="10dp"/>

        <!-- Accessibility Button -->
        <Button
            android:id="@+id/btnAccessibilitySettings"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Open Accessibility Settings"
            android:backgroundTint="#3949AB"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"/>

        <!-- Emergency Button -->
        <Button
            android:id="@+id/btnEmergency"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Emergency Exit (10 mins)"
            android:backgroundTint="#FFA000"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="20dp" />

        <!-- Subheading -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Apps to Block:"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#263238"
            android:layout_marginTop="25dp"
            android:paddingBottom="10dp"/>

        <!-- App List -->
        <ListView
            android:id="@+id/lvApps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView>
